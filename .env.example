# Copy to .env and fill in. .env is gitignored — never commit real values.
# NOTE: do NOT put ANTHROPIC_API_KEY here. The run uses your logged-in Claude Pro CLI.

TTS_BACKEND=kokoro

# --- Publish backend ---------------------------------------------------------
# github  (default)  Audio -> GitHub Release asset; feed.xml + cover served from
#                    docs/ via GitHub Pages. No storage credentials needed — uses
#                    the locally authenticated `gh` CLI + git. Self-contained.
# s3                 Audio + feed.xml -> S3-compatible bucket (AWS S3 or Cloudflare
#                    R2 via S3_ENDPOINT_URL). Needs the S3_*/AWS_* creds below.
PUBLISH_BACKEND=github

# --- Podcast metadata (used by both backends to build the RSS feed) ----------
# Quote any value with spaces — run_episode.sh sources this file with `set -a`.
SHOW_TITLE="Your AI Daily"
SHOW_DESC="A grounded 15-minute daily briefing on AI papers, releases, and news."
SHOW_AUTHOR="Your Name"
OWNER_EMAIL="you@example.com"         # Spotify sends the verification code here
SHOW_CATEGORY="Technology"

# --- github backend ----------------------------------------------------------
# Cover is copied from here to docs/cover.png and served by Pages. No COVER_URL needed.
COVER_SRC="assets/podcast_cover.png"
# PAGES_URL=https://media.yourdomain.com   # only if you map a custom domain to Pages

# --- s3 / r2 backend (only if PUBLISH_BACKEND=s3) ----------------------------
# S3_BUCKET=your-podcast-bucket
# S3_REGION=auto                           # "auto" for R2; e.g. us-east-1 for AWS
# S3_ENDPOINT_URL=https://<accountid>.r2.cloudflarestorage.com   # omit for AWS S3
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# PUBLIC_BASE_URL=https://media.yourdomain.com   # public base that serves the bucket
# COVER_URL=https://media.yourdomain.com/cover.png
